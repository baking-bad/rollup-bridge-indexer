# Self-contained env for the Docker smoke test (tests/e2e/smoke_test.sh).
#
# Values are deliberately dummy: the smoke test never connects to a chain, it only
# checks that the image builds, the `rollup_bridge_indexer` package resolves and its
# submodules import, and that a base + overlay config validates. The addresses below
# are real *public* on-chain addresses (not secrets) so config validation passes;
# the URLs are placeholders. NETWORK must match the overlay smoke_test.sh loads.
NETWORK=shadownet

# URLs — never dialed by `package verify` / `config export`; only used by `--boot`,
# which still expects TZKT_URL to be reachable for datasource init.
TZKT_URL=https://api.tzkt.io
METADATA_URL=https://metadata.example
TEZOS_NODE_URL=https://rpc.example
ETHERLINK_NODE_URL=https://evm.example
ETHERLINK_SUBSQUID_URL=https://subsquid.example
ROLLUP_NODE_URL=https://rollup.example
HASURA_URL=http://hasura:8080

# Public on-chain addresses (shadownet) — required for config + on_reindex validation.
SMART_ROLLUP_ADDRESS=sr19fMYrr5C4qqvQqQrDSjtP31GcrWjodzvg
FAST_WITHDRAWAL_NATIVE_ADDRESS=KT1E1f7ze8FcjbFu4UwnBqNo4kbbS6Zo5Y9W
NATIVE_TICKETER=KT1JYZsawXmeArts18nn4uT79tUJc4AGTYgc
FA_TICKETERS=["KT1XMMCQuJFd7KRxoPd8FZda39dATPay1nZA", "KT1FLeK36Ghijo1eYstijYSj3wsDZFhk2vUo", "KT1LdyznoJDzUqsgE8zpM242W1BBi42S8img"]

# Sync window (consumed by the shadownet overlay).
L1_FIRST_LEVEL=210588
L2_FIRST_LEVEL=500000

# L2 Michelson side (consumed by the tezosx-shadownet overlay only).
TEZOSX_MICHELSON_TZKT_URL=https://michelson-tzkt.example
L2_MICHELSON_FIRST_LEVEL=560000
