# Block window for the michelson-l2-deposit OP-HASH case (same verified pair as the
# sibling `michelson_l2_deposit` case, <10 blocks/chain).
# L2 Michelson opAhDWYxwDWFnKXG892itvC1TmMtUbeuSThVopzVDGd41mRxomE @ previewnet 562967
#   (amount 1000000, tz1Ke2h7…->tz1PSJR6…)
# L1 shadownet ooGrnVtriNUXUPpsFWaKGtFkM4MfroTHmvHs9BUzC53ewVCveC9 @ 3599297 (amount 1000000)
#   inbox (level=3599297, index=8) -> reconstructs the L2 op-hash above.

# L1 (shadownet) window — brackets the internal rollup `default` call.
L1_FIRST_LEVEL=3599295
L1_LAST_LEVEL=3599299

# L2 Michelson (previewnet) window — brackets the depositor->tz1 pseudo-transaction.
L2_MICHELSON_FIRST_LEVEL=562965
L2_MICHELSON_LAST_LEVEL=562969

# Rollup inbox-backfill window (on_restart) — brackets inbox level 3599297.
ROLLUP_SYNC_FIRST_LEVEL=3599290
ROLLUP_SYNC_LAST_LEVEL=3599300

SQLITE_PATH=/tmp/bridge_michelson_l2_deposit_ophash.sqlite
