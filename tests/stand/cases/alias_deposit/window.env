# alias-deposit on-chain sample (live 2026-06-17). All deposits TO alias
# 0x21ab829afe4b41dd3fb6eb5be4de2d20d9cebc21 -> tz1ekkzEN2LB1cpf7dCaonKt6x9KVd9YVydc (originOf kind=2):
#   block 781932  XTZ before init  from 0x…feed, value 1991000000000000 (1991 mutez)
#   block 782100  FA  before init  Deposit event on 0xff…02, amount 1997
#   block 782541  XTZ after init   from 0x…feed, value 0.5e18
#   block 782544  FA  after init   different (queued/claim) event the on_deposit ABI ignores -> NOT indexed

# Etherlink L2 window (brackets all four deposit txs)
L2_FIRST_LEVEL=781930
L2_LAST_LEVEL=782546

# Rollup inbox-backfill window (on_restart) — irrelevant to this case, kept tiny.
ROLLUP_SYNC_FIRST_LEVEL=3599290
ROLLUP_SYNC_LAST_LEVEL=3599300

SQLITE_PATH=/tmp/bridge_alias_deposit.sqlite
