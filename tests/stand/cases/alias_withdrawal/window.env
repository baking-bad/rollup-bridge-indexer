# alias-withdrawal on-chain sample (live 2026-06-17). All withdrawals FROM alias
# 0x21ab829afe4b41dd3fb6eb5be4de2d20d9cebc21 -> tz1ekkzEN2LB1cpf7dCaonKt6x9KVd9YVydc (originOf kind=2):
#   block 782359  XTZ  Withdrawal on 0xff…01, amount 0.5e18, withdrawal_id 80
#   block 782467  FA   Withdrawal on 0xff…02, amount 1, withdrawal_id 0
# (the window also catches an extra XTZ withdrawal at 782445 — all resolve to the same origin.)

# Etherlink L2 window (brackets both withdrawals)
L2_FIRST_LEVEL=782350
L2_LAST_LEVEL=782475

# Rollup inbox-backfill window (on_restart) — irrelevant to this case, kept tiny.
ROLLUP_SYNC_FIRST_LEVEL=3599290
ROLLUP_SYNC_LAST_LEVEL=3599300

SQLITE_PATH=/tmp/bridge_alias_withdrawal.sqlite
