# alias-recheck on-chain sample (live 2026-06-18). Three XTZ deposits, all TO the same non-alias
# EVM receiver 0x7e6f6ccfe485a087f0f819eabfdbfb1a49b97677 (originOf kind=1, native — its own origin):
#   block 796025  XTZ  from 0x…feed, value 62992000000000000
#   block 796027  XTZ  from 0x…feed, value  5432000000000000
#   block 796029  XTZ  from 0x…feed, value 83412000000000000

# Force every repeat sighting past the recheck cooldown so the re-resolution branch fires.
ALIAS_RECHECK_SECONDS=0

# Etherlink L2 window (brackets the three deposit txs)
L2_FIRST_LEVEL=796024
L2_LAST_LEVEL=796030

# Rollup inbox-backfill window (on_restart) — irrelevant to this case, kept tiny.
ROLLUP_SYNC_FIRST_LEVEL=3599290
ROLLUP_SYNC_LAST_LEVEL=3599300

SQLITE_PATH=/tmp/bridge_alias_recheck.sqlite
