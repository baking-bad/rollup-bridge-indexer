# Block window for the inbox-backfill START-LEVEL case.
#
# The FIRST XTZ deposit of the network: L1 3102183 — inbox transfer (3102183, 8),
# 10 XTZ to tz1KqTpEZ7Yob7QbPE4Hy4Wo8fHG8LhKxZSx. This deposit also MINTED the
# native xtz ticket, so the native ticket's firstLevel == this very level — months
# before the FA ticketers' first ticket (3618904). An FA-only first_ticket_level
# starts the backfill at 3618904 and silently skips this deposit's inbox message.
#
# CRITICAL: no ROLLUP_SYNC_FIRST_LEVEL here. That test override would replace the
# logic under test — the production fresh-DB start decision in
# RollupMessageIndex._prepare_new_index. Only the upper bound is set, to keep the
# run oneshot-fast (the backfill flips realtime at the first message past it).

# L1 (shadownet) window — brackets the deposit op at 3102183.
L1_FIRST_LEVEL=3102180
L1_LAST_LEVEL=3102190

# Upper bound only (see above).
ROLLUP_SYNC_LAST_LEVEL=3102190

SQLITE_PATH=/tmp/bridge_inbox_backfill_first_level.sqlite
