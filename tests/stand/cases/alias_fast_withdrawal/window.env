# alias-fast-withdrawal on-chain sample (live 2026-06-18). A fast XTZ withdrawal initiated via NAC:
# native tz1ekkz… calls call_evm, the NAC enters the EVM runtime as the alias 0x21ab… and emits a
# FastWithdrawal on 0xff…01. The handler resolves the l2_caller (the alias) back to its tz origin.
#   block 796093  FastWithdrawal on 0xff…01, l2_caller 0x21ab… -> tz1ekkz…,
#                 amount 10000000000000000, withdrawal_id 87, fast_payload 5 bytes
# EVM tx 0x345ae90bc59b01cb4895f85fe77aef329958e6aaa7964e4d7e823f4026dd5214

# Etherlink L2 window (brackets the FastWithdrawal event)
L2_FIRST_LEVEL=796090
L2_LAST_LEVEL=796096

# Rollup inbox-backfill window (on_restart) — irrelevant to this case, kept tiny.
ROLLUP_SYNC_FIRST_LEVEL=3599290
ROLLUP_SYNC_LAST_LEVEL=3599300

SQLITE_PATH=/tmp/bridge_alias_fast_withdrawal.sqlite
