# Template for the block-bounded test-indexer stand (see TESTING.md).
#   cp tests/stand/tezosx-shadownet-test.env.default tests/stand/tezosx-shadownet-test.env
# then set the windows around the deposit you want to verify.
#
# This file holds ONLY block-window knobs — no secrets. URLs/addresses come from the prod
# env (TEST_ENV, default .env.tezosx-shadownet), sourced first by `make test-indexer`; this
# override is sourced AFTER it. The values below are a working example (Candidate A:
# 9985 XTZ deposit, L1 3428081 -> L2 388226) — replace them for a different deposit.

# Tezos L1 window (brackets the on_rollup_call deposit op)
L1_FIRST_LEVEL=3428078
L1_LAST_LEVEL=3428084

# Etherlink L2 window (brackets the synthetic XTZ-credit block)
L2_FIRST_LEVEL=388221
L2_LAST_LEVEL=388231

# Rollup inbox-backfill window (on_restart). Without these the backfill reads ALL
# ~18M inbox messages from origination. Bracket the deposit's inbox transfer.
ROLLUP_SYNC_FIRST_LEVEL=3428070
ROLLUP_SYNC_LAST_LEVEL=3428090

# Throwaway sqlite (wiped on each `make test-indexer`)
SQLITE_PATH=/tmp/bridge_tezosx_test.sqlite
